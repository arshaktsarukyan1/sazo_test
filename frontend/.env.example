# Server-side proxy to Laravel (never exposed to the browser). Omit for default http://localhost.
# Docker Compose sets http://backend:8000 on the frontend service — use .env.local only if you override.
# Host `npm run dev` + nginx on :80: http://localhost | artisan only: http://127.0.0.1:8000
# TDS_BACKEND_URL=http://127.0.0.1:8000
# Same value as Laravel INTERNAL_API_TOKEN. Alias: you may set INTERNAL_API_TOKEN instead.
# Match backend INTERNAL_API_TOKEN exactly (see backend/.env.example).
TDS_INTERNAL_API_TOKEN=change-me

# Shown in the campaign builder for tracking URLs (browser-facing origin, e.g. nginx host)
NEXT_PUBLIC_TDS_PUBLIC_ORIGIN=http://localhost
