{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": false,
    "plugins": [{ "name": "next" }],
    "baseUrl": "./frontend",
    "paths": {
      "@/*": ["./src/*"]
    },
    "typeRoots": ["./frontend/node_modules/@types"],
    "types": ["node", "react", "react-dom"]
  },
  "include": [
    "frontend/next-env.d.ts",
    "frontend/**/*.ts",
    "frontend/**/*.tsx",
    "frontend/.next/types/**/*.ts"
  ],
  "exclude": ["frontend/node_modules", "backend"]
}
