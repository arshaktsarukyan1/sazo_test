COMPOSE_PROJECT_NAME=tds

# UID/GID for npm/next inside the frontend container (entrypoint chowns node_modules/.next, then su-exec).
# Set to your host `id -u` / `id -g` so bind-mounted files match your user when using host `npm run dev`.
DOCKER_UID=1000
DOCKER_GID=1000

MYSQL_DATABASE=tds
MYSQL_USER=tds
MYSQL_PASSWORD=tds
MYSQL_ROOT_PASSWORD=tds

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
SHOPIFY_WEBHOOK_URL=http://localhost/api/v1/webhooks/shopify/orders
